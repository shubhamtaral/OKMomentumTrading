# ============================================================
# OK Momentum Screener — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The application reads these at startup via dotenv.
# ============================================================

# -- Server ----------------------------------------------------------
PORT=3000
NODE_ENV=development

# -- Database --------------------------------------------------------
# PostgreSQL connection string for managed databases (Supabase, Neon, RDS)
# Example: postgres://user:password@hostname:5432/dbname
DATABASE_URL=

# -- AI Intelligence -------------------------------------------------
# OpenAI or OpenRouter API key for advisory narratives
# OpenRouter keys should start with 'sk-or-...'
OPENAI_API_KEY=

# -- Scheduler -------------------------------------------------------
# Cron expression for the daily data pipeline (UTC timezone).
# Default: '30 14 * * *' = 14:30 UTC = 20:00 IST
CRON_EXPRESSION=30 14 * * *

# -- OHLC Ingest tuning ----------------------------------------------
# Number of symbols processed concurrently per batch (default: 20)
OHLC_BATCH_SIZE=20

# Milliseconds to wait between batches to avoid Yahoo rate-limits (default: 1500)
OHLC_BATCH_DELAY_MS=1500
